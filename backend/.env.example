# === Required ===
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed frontend origins. No trailing slash, no wildcards.
# Example for prod: ALLOWED_ORIGINS=https://prodigy-fs-02.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# Supabase — get these from https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Long random string. Generate: openssl rand -base64 64
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d
